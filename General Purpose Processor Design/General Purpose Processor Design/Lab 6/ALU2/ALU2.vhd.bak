zLIBRARY ieee;
USE ieee.std_logic_1164.all;
USE ieee.std_logic_unsigned.all;
USE ieee.numeric_std.all;


entity ALU2 is -- ALU unit includes Reg. 3
    port (
        clk    : in std_logic;
        A, B   : in unsigned(7 downto 0); -- 8-bit inputs A & B from Reg. 1 & Reg. 2
        opcode : in unsigned(7 downto 0); -- 8-bit opcode from Decoder
        Neg    : out std_logic;
        R1, R2 : out unsigned(3 downto 0)
    );
end ALU2;

architecture calculation of ALU2 is
    signal Reg1, Reg2, Result : unsigned(7 downto 0) := (others => '0'); -- 8-bit Result
begin
    Reg1 <= A;
    Reg2 <= B;

    process(clk)
    begin
        if rising_edge(clk) then
            case opcode is
                when "00000001" => -- Increment A by 2
                    Result = Reg1 + "10";

                when "00000010" => -- Shift B to the righ5t  
                    Result = Reg2 / 2;

                when "00000100" => -- Do inverse
                    Neg <= '0';
                    Result <= not Reg1;

                when "00001000" => -- Do Boolean NAND
                    Neg <= '0';
                    Result <= not (Reg1 and Reg2);

                when "00010000" => -- Do Boolean NOR
                    Neg <= '0';
                    Result <= not (Reg1 or Reg2);

                when "00100000" => -- Do Boolean AND
                    Neg <= '0';
                    Result <= Reg1 and Reg2;

                when "01000000" => -- Do Boolean XOR
                    Neg <= '0';
                    Result <= Reg1 xor Reg2;

                when "10000000" => -- Do Boolean OR
                    Neg <= '0';
                    Result <= Reg1 or Reg2;

                when others => -- don't care, do nothing
                    Result <= (others => '0');
                    Neg <= '0';
            end case;
        end if;
    end process;

    -- Assigning 4-bit outputs
    R1 <= Result(3 downto 0); -- Lower 4 bits
    R2 <= Result(7 downto 4); -- Upper 4 bits
end calculation;

