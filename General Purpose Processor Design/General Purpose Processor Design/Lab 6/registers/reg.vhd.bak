library ieee;
use ieee.std_logic_1164.all;

entity reg is
    port (
        A: in std_logic_vector(7 downto 0);   -- 8-bit A input
        res, clk: in std_logic;           -- 1-bit clock input and 1-bit reset input
        Q: out std_logic_vector(7 downto 0)    -- 8-bit output
    );
end reg;

architecture Behavior of reg is
begin
    process (res, clk)   -- Process takes reset and clock as inputs
    begin
        if res = '1' then   -- when reset input is '0', the latch does not operate
            Q <= "00000000";
        elsif (clk'EVENT AND clk = '1') then   -- rising edge sensitive based on clock
            Q <= A;
        end if;
    end process;
end Behavior;